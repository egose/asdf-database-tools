#!/usr/bin/env bash
set -eo pipefail

: "${ASDF_INSTALL_VERSION:?"Missing ASDF_INSTALL_VERSION"}"
: "${ASDF_INSTALL_PATH:?"Missing ASDF_INSTALL_PATH"}"

echo "ASDF_INSTALL_VERSION: $ASDF_INSTALL_VERSION"
echo "ASDF_INSTALL_PATH: $ASDF_INSTALL_PATH"

tool_name="database-tools"
github_coordinates="egose/${tool_name}"
base_download_url="https://github.com/${github_coordinates}/releases/download"

install_tool() {
  local version=$1
  local install_path=$2
  local bin_install_path="${install_path}/bin"
  local platform
  local arch
  local tempdir

  platform=$(uname | tr '[:upper:]' '[:lower:]')
  arch=$(uname -m | tr '[:upper:]' '[:lower:]')

  # Architecture Normalization:
  # x86_64 and amd64 refer to the same architecture.
  # - x86_64: This is the 64-bit extension of the x86 instruction set, first introduced by AMD.
  #   It's the technical name often used in Linux distributions.
  # - amd64: This name originates from AMD when they developed the 64-bit extension for
  #   the x86 architecture, and it's often used in contexts like Debian package names and Windows installers.
  case "$arch" in
  x86_64 | amd64 | x64)
    arch="amd64"
    ;;
  aarch64 | arm64)
    arch="arm64"
    ;;
  *)
    echo "Unsupported architecture: $arch"
    exit 1
    ;;
  esac

  echo "Platform: $platform, Architecture: $arch"

  # Use a trap to ensure cleanup of the temp directory even on failure
  tempdir=$(mktemp -d "asdf-${tool_name}.XXXX")
  trap 'rm -rf "$tempdir"' EXIT

  local shortname="${platform}-${arch}.tar.gz"
  local filenames=("${shortname}" "${tool_name}-${shortname}")

  # Attempt to download each potential filename
  for filename in "${filenames[@]}"; do
    local download_url="${base_download_url}/v${version}/${filename}"
    local tempfile="${tempdir}/${filename}"

    echo "Attempting to download: $download_url"

    # Download with a timeout and retry for reliability
    if curl -L --fail --connect-timeout 10 --retry 3 "${download_url}" -o "${tempfile}"; then
      echo "Download successful. Installing to $bin_install_path"
      mkdir -p "$bin_install_path"

      tar -zxf "${tempfile}" -C "$bin_install_path"

      echo "Installation complete."
      return 0
    else
      echo "Download failed for: $filename. Trying next variant..."
    fi
  done

  echo "Error: All download attempts failed for $tool_name v$version."
  exit 1
}

install_tool "$ASDF_INSTALL_VERSION" "$ASDF_INSTALL_PATH"
